# Database — replace with your real Postgres connection string
# Local dev example: postgresql://postgres:password@localhost:5432/event_registration
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/event_registration"

# Server
PORT=4000
NODE_ENV=development

# Base URL used to build short links printed on QR flyers
# Local network example: http://192.168.1.10:4000
# Production example: https://moe-events.ng
BASE_URL="http://localhost:4000"

# Auth (Phase 6) — generate a real random secret before production, e.g.:
# node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="replace-this-with-a-long-random-string"
JWT_EXPIRES_IN="12h"

# CORS — comma separated list of allowed frontend origins
CORS_ORIGINS="http://localhost:5173,http://localhost:5174"

# In production, set this to true so Express serves the built frontend from ../frontend/dist
SERVE_FRONTEND="true"
